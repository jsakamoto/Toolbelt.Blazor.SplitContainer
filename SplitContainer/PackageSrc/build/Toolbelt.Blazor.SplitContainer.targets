<Project>

  <PropertyGroup>
    <ToolbeltBlazorSplitContainerJavaScriptCacheBusting Condition=" '$(ToolbeltBlazorSplitContainerJavaScriptCacheBusting)' == '' ">true</ToolbeltBlazorSplitContainerJavaScriptCacheBusting>
  </PropertyGroup>

  <ItemGroup Condition=" '$(RuntimeIdentifier)' == 'browser-wasm' AND '$(ToolbeltBlazorSplitContainerJavaScriptCacheBusting)' != '' ">
    <RuntimeHostConfigurationOption Include="Toolbelt.Blazor.SplitContainer.JavaScriptCacheBusting" Value="$(ToolbeltBlazorSplitContainerJavaScriptCacheBusting)" Trim="true" />
  </ItemGroup>

</Project>